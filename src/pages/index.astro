---
import BaseLayout from '../layouts/BaseLayout.astro'; import Hero from '../components/Hero.astro'; import SectionTitle from '../components/SectionTitle.astro'; import GoldenDivider from '../components/GoldenDivider.astro'; import DisclaimerBox from '../components/DisclaimerBox.astro';
const base = import.meta.env.BASE_URL;
const internalUrl = (path: string) => `${base}${path.replace(/^\//, '')}`;
---
<BaseLayout title="Além do Rei do Pop | Homenagem independente" description="Uma homenagem cultural e independente ao legado, à arte e à humanidade de Michael Jackson.">
  <Hero />
  <section class="bg-paper py-24 text-[#202126]"><div class="shell"><SectionTitle eyebrow="O projeto" title="Memória com contexto" text="Este espaço observa uma trajetória artística monumental sem apagar sua complexidade. Reunimos textos autorais, marcos históricos e vozes de fãs em uma experiência editorial independente." /><GoldenDivider /><div class="grid gap-6 md:grid-cols-3"><a href={internalUrl('/historia')} class="rounded-2xl bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl"><span class="eyebrow">01</span><h2 class="mt-4 font-display text-3xl">Uma trajetória</h2><p class="mt-3 leading-7 text-black/55">Da infância em Gary à construção de uma linguagem artística global.</p></a><a href={internalUrl('/discografia')} class="rounded-2xl bg-[#132139] p-7 text-white transition hover:-translate-y-1 hover:shadow-xl"><span class="eyebrow">02</span><h2 class="mt-4 font-display text-3xl">Obras em contexto</h2><p class="mt-3 leading-7 text-white/55">Leituras autorais sobre álbuns, escolhas criativas e impacto cultural.</p></a><a href={internalUrl('/mensagens.html')} class="rounded-2xl bg-[#d1b469] p-7 text-[#18130a] transition hover:-translate-y-1 hover:shadow-xl"><span class="text-xs font-semibold uppercase tracking-[.28em]">03</span><h2 class="mt-4 font-display text-3xl">Memória coletiva</h2><p class="mt-3 leading-7 text-black/60">Relatos aprovados de quem mantém essa arte presente no cotidiano.</p></a></div><div class="mt-12"><DisclaimerBox /></div></div></section>
  <section class="bg-navy py-24"><div class="shell grid items-center gap-12 lg:grid-cols-2"><figure class="overflow-hidden rounded-[1.75rem] border border-white/10 bg-black/25 shadow-2xl shadow-black/30"><img src="/assets/licensed/michael-jackson-in-1988.jpg" alt="Michael Jackson em imagem licenciada usada na abertura da seção Explore" class="aspect-[4/3] w-full object-cover object-top" loading="lazy" decoding="async" /><figcaption class="border-t border-white/10 px-4 py-3 text-[.62rem] uppercase tracking-[.24em] text-white/40"><a href="https://commons.wikimedia.org/wiki/File:Michael_Jackson_in_1988.jpg" target="_blank" rel="noopener noreferrer" class="text-champagne underline decoration-gold/40 underline-offset-4">Fonte licenciada</a></figcaption></figure><div><p class="eyebrow">Explore</p><h2 class="display mt-4 text-5xl">Mais do que números: uma linguagem.</h2><p class="mt-6 leading-8 text-white/60">Dança, moda, videoclipes e performance foram transformados por uma busca obsessiva por detalhe. O legado vive tanto nas grandes referências quanto nos pequenos gestos que outros artistas continuam a reinterpretar.</p><a href={internalUrl('/legado')} class="btn-primary mt-8">Explorar o legado</a></div></div></section>
</BaseLayout>
