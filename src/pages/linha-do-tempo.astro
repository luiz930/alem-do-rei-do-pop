---
import BaseLayout from '../layouts/BaseLayout.astro'; import SectionTitle from '../components/SectionTitle.astro'; import Timeline from '../components/Timeline.astro'; import timeline from '../data/timeline.json';
---
<BaseLayout title="Linha do tempo | Além do Rei do Pop" description="Marcos da trajetória artística, cultural e humanitária de Michael Jackson."><section class="noise py-24"><div class="shell"><div class="grid items-center gap-12 lg:grid-cols-[1fr_.72fr]"><SectionTitle eyebrow="Linha do tempo" title="Décadas em movimento" text="Uma seleção de marcos para localizar fases criativas. A cronologia não pretende resumir toda a história." /><figure class="overflow-hidden rounded-3xl border border-white/10 bg-black shadow-lg"><img src="/assets/licensed/michael-jackson-1977.jpg" alt="Michael Jackson em imagem licenciada usada na linha do tempo" class="aspect-[4/3] w-full object-cover object-top" loading="lazy" decoding="async" /><figcaption class="border-t border-white/10 px-4 py-3 text-[.62rem] uppercase tracking-[.24em] text-white/45"><a href="https://commons.wikimedia.org/wiki/File:Michael_Jackson_1977.JPG" target="_blank" rel="noopener noreferrer" class="underline decoration-gold/40 underline-offset-4">Fonte licenciada</a></figcaption></figure></div><div class="mt-20"><Timeline events={timeline} /></div></div></section></BaseLayout>
