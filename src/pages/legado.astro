---
import BaseLayout from '../layouts/BaseLayout.astro'; import SectionTitle from '../components/SectionTitle.astro';
const topics=[['Dança','Isolamentos, deslizes, pausas e explosões de energia foram organizados em frases corporais legíveis até em silhueta. A influência está menos em um passo isolado e mais na ideia de que movimento também narra.'],['Moda','Chapéus, luvas, jaquetas estruturadas e contrastes gráficos ajudaram a criar personagens de palco. A roupa não funcionava como adorno, mas como extensão do gesto e da luz.'],['Videoclipe','A promoção de uma canção tornou-se território de cinema: roteiro, elenco, efeitos e coreografia passaram a construir universos com começo, tensão e desfecho.'],['Performance','Voz ao vivo, desenho de palco, suspense e precisão foram pensados em conjunto. Grandes shows pop ainda usam essa integração como referência.'],['Cultura pop','Paródias, homenagens, jogos e redes sociais mantêm símbolos em circulação. Essa presença exige leitura crítica sobre contexto, autoria e transformação.'],['Novos artistas','A influência aparece em treinamento multidisciplinar, videoclipes ambiciosos e apresentações que tratam câmera e plateia como públicos simultâneos.']];
---
<BaseLayout theme="light" title="Legado cultural | Além do Rei do Pop" description="A influência de Michael Jackson na dança, moda, videoclipes, performance e cultura pop."><section class="py-24"><div class="shell"><div class="grid items-center gap-12 lg:grid-cols-[1fr_.72fr]"><SectionTitle eyebrow="Legado cultural" title="Uma gramática que continua sendo falada" text="Influência não é repetição. É o ponto a partir do qual novas gerações escolhem copiar, questionar, combinar e inventar." /><figure class="overflow-hidden rounded-3xl border border-black/10 bg-white shadow-lg"><img src="/assets/licensed/michael-jackson-1984.jpg" alt="Michael Jackson em imagem licenciada usada na seção de legado" class="aspect-[4/3] w-full object-cover object-top" loading="lazy" decoding="async" /><figcaption class="border-t border-black/10 px-4 py-3 text-[.62rem] uppercase tracking-[.24em] text-black/45"><a href="https://commons.wikimedia.org/wiki/File:Michael_Jackson_1984.jpg" target="_blank" rel="noopener noreferrer" class="underline decoration-[#b08b3e]/40 underline-offset-4">Fonte licenciada</a></figcaption></figure></div><div class="mt-16 grid gap-px overflow-hidden rounded-3xl bg-black/10 md:grid-cols-2 lg:grid-cols-3">{topics.map(([title,text],i)=><article class="bg-paper p-8 sm:p-10"><span class="font-display text-5xl text-[#b08b3e]/30">0{i+1}</span><h2 class="mt-8 font-display text-4xl">{title}</h2><p class="prose-copy mt-4">{text}</p></article>)}</div></div></section></BaseLayout>
