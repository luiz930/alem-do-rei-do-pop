---
import BaseLayout from '../layouts/BaseLayout.astro'; import SectionTitle from '../components/SectionTitle.astro'; import TypographicArt from '../components/TypographicArt.astro';
const topics=[['Dança','Isolamentos, deslizes, pausas e explosões de energia foram organizados em frases corporais legíveis até em silhueta. A influência está menos em um passo isolado e mais na ideia de que movimento também narra.'],['Moda','Chapéus, luvas, jaquetas estruturadas e contrastes gráficos ajudaram a criar personagens de palco. A roupa não funcionava como adorno, mas como extensão do gesto e da luz.'],['Videoclipe','A promoção de uma canção tornou-se território de cinema: roteiro, elenco, efeitos e coreografia passaram a construir universos com começo, tensão e desfecho.'],['Performance','Voz ao vivo, desenho de palco, suspense e precisão foram pensados em conjunto. Grandes shows pop ainda usam essa integração como referência.'],['Cultura pop','Paródias, homenagens, jogos e redes sociais mantêm símbolos em circulação. Essa presença exige leitura crítica sobre contexto, autoria e transformação.'],['Novos artistas','A influência aparece em treinamento multidisciplinar, videoclipes ambiciosos e apresentações que tratam câmera e plateia como públicos simultâneos.']];
---
<BaseLayout theme="light" title="Legado cultural | Além do Rei do Pop" description="A influência de Michael Jackson na dança, moda, videoclipes, performance e cultura pop."><section class="py-24"><div class="shell"><div class="grid items-center gap-12 lg:grid-cols-[1fr_.72fr]"><SectionTitle eyebrow="Legado cultural" title="Uma gramática que continua sendo falada" text="Influência não é repetição. É o ponto a partir do qual novas gerações escolhem copiar, questionar, combinar e inventar." /><TypographicArt variant="dance" ratio="wide" label="Dançarino tipográfico formado por letras, números e palavras ligadas ao ritmo" title="DANCE • RHYTHM • LEGACY" /></div><div class="mt-16 grid gap-px overflow-hidden rounded-3xl bg-black/10 md:grid-cols-2 lg:grid-cols-3">{topics.map(([title,text],i)=><article class="bg-paper p-8 sm:p-10"><span class="font-display text-5xl text-[#b08b3e]/30">0{i+1}</span><h2 class="mt-8 font-display text-4xl">{title}</h2><p class="prose-copy mt-4">{text}</p></article>)}</div></div></section></BaseLayout>
