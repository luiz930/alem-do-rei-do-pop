---
import BaseLayout from '../layouts/BaseLayout.astro';

const description = 'Um convite para transformar amor, esperança e consciência em pequenas atitudes capazes de construir um futuro melhor.';
const reflections = [
  ['01', 'Como estou ajudando a construir o futuro?'],
  ['02', 'Quem precisa da minha ajuda hoje?'],
  ['03', 'Que impacto minhas palavras causam?'],
  ['04', 'Estou espalhando esperança ou medo?'],
  ['05', 'Se todos agissem como eu, o mundo seria melhor?']
];
const timeline = ['Hoje', 'Pequenas ações', 'Consciência coletiva', 'Transformação', 'Futuro melhor'];
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Heal the World Project',
  description,
  inLanguage: 'pt-BR',
  isPartOf: { '@type': 'WebSite', name: 'Além do Rei do Pop', url: Astro.site }
};
---

<BaseLayout title="Heal the World Project | Além do Rei do Pop" description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />

  <div class="heal-page">
    <section class="hero-hope" aria-labelledby="hero-title">
      <div class="stars" aria-hidden="true"></div>
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="earth-wrap" aria-hidden="true">
        <div class="earth">
          <span class="land land-one"></span><span class="land land-two"></span><span class="land land-three"></span>
        </div>
        <span class="orbit"></span>
      </div>
      <div class="shell relative z-10 flex min-h-[calc(100svh-4rem)] items-center py-24">
        <div class="hero-copy reveal-item max-w-3xl">
          <p class="hope-label">Uma missão para todos nós</p>
          <h1 id="hero-title">Heal the<br/><em>World</em> Project</h1>
          <p class="hero-subtitle">O futuro da humanidade começa nas escolhas que fazemos hoje.</p>
          <a href="#manifesto" class="hope-button">Começar minha missão <span aria-hidden="true">↓</span></a>
        </div>
      </div>
      <p class="scroll-note" aria-hidden="true">Explore o manifesto</p>
    </section>

    <section id="manifesto" class="light-section section-space">
      <div class="shell manifesto-grid">
        <div class="reveal-item">
          <p class="hope-label dark">Manifesto</p>
          <h2 class="hope-title">O progresso começa por dentro.</h2>
          <p class="lead-copy">Um mundo mais justo não surge de um único grande gesto. Ele nasce das decisões silenciosas que repetimos todos os dias.</p>
        </div>
        <div class="principles">
          <article class="principle reveal-item"><span>01</span><div><h3>Escolhas importam</h3><p>Pequenas atitudes ganham força quando se tornam parte de uma cultura de cuidado.</p></div></article>
          <article class="principle reveal-item"><span>02</span><div><h3>O futuro é humano</h3><p>A tecnologia amplia possibilidades, mas somente a consciência define como iremos usá-las.</p></div></article>
          <article class="principle reveal-item"><span>03</span><div><h3>Consciência é evolução</h3><p>Escutar, compreender e agir com responsabilidade é o avanço de que mais precisamos.</p></div></article>
        </div>
      </div>
    </section>

    <section class="mission-section section-space" aria-labelledby="mission-heading">
      <div class="shell text-center">
        <p class="hope-label">Transforme intenção em ação</p>
        <h2 id="mission-heading" class="hope-title light">Sua missão de hoje</h2>
        <div class="mission-card reveal-item" aria-live="polite" aria-atomic="true">
          <div class="mission-icon" aria-hidden="true">✦</div>
          <p id="mission-title">Missão disponível</p>
          <p id="mission-text">Clique no botão para receber uma missão ligada à ideia de Heal the World.</p>
          <span id="mission-count">10 missões curadas</span>
        </div>
        <button id="generate-mission" class="hope-button" type="button">Gerar uma missão <span aria-hidden="true">✦</span></button>
      </div>
    </section>

    <section class="light-section section-space">
      <div class="shell">
        <div class="section-heading reveal-item"><p class="hope-label dark">Pausa consciente</p><h2 class="hope-title">Perguntas que movem o mundo</h2><p>Não é preciso ter todas as respostas. É preciso coragem para fazer as perguntas certas.</p></div>
        <div class="reflection-grid">
          {reflections.map(([number, question]) => <article class="reflection-card reveal-item"><span>{number}</span><h3>{question}</h3><div aria-hidden="true">↗</div></article>)}
        </div>
      </div>
    </section>

    <section class="future-section section-space" aria-labelledby="future-heading">
      <div class="shell">
        <div class="section-heading center reveal-item"><p class="hope-label">O futuro da humanidade</p><h2 id="future-heading" class="hope-title light">Toda transformação tem um começo.</h2></div>
        <ol class="future-timeline">
          {timeline.map((item, index) => <li class="reveal-item"><span>{String(index + 1).padStart(2, '0')}</span><strong>{item}</strong>{index < timeline.length - 1 && <i aria-hidden="true">↓</i>}</li>)}
        </ol>
      </div>
    </section>

    <section class="light-section section-space" aria-labelledby="world-heading">
      <div class="shell world-grid">
        <div class="reveal-item"><p class="hope-label dark">Um planeta, bilhões de escolhas</p><h2 id="world-heading" class="hope-title">A bondade não conhece fronteiras.</h2><p class="lead-copy">Imagine milhões de pessoas praticando pequenos atos de bondade ao redor do planeta.</p></div>
        <div class="world-map reveal-item">
          <svg viewBox="0 0 900 450" role="img" aria-label="Mapa-múndi estilizado com pontos luminosos distribuídos pelos continentes">
            <defs><radialGradient id="dot"><stop stop-color="#fff"/><stop offset=".25" stop-color="#62e6c5"/><stop offset="1" stop-color="#22c99a" stop-opacity="0"/></radialGradient></defs>
            <g class="continents"><path d="M72 103l43-38 83 9 31 32 46 16 20 45-35 37-22 63-37 26-33-69-38-20-18-59z"/><path d="M263 276l53 15 34 63-28 81-33-41-12-60z"/><path d="M397 101l67-28 69 17 40-17 94 34 95 4 72 45-35 33-71-8-44 31-50-14-51 48-49-2-32-45-65-9-40-49z"/><path d="M461 226l72 8 42 48-15 94-48 53-41-58-31-91z"/><path d="M719 306l54-25 66 37-16 50-73 11-43-35z"/></g>
            <g class="map-dots">{[[141,126],[210,164],[178,239],[306,322],[327,380],[446,128],[508,164],[533,264],[512,337],[598,138],[653,180],[704,145],[760,176],[793,327],[735,341]].map(([cx,cy],i)=><circle cx={cx} cy={cy} r="18" fill="url(#dot)" style={`animation-delay:${i * -.22}s`} />)}</g>
          </svg>
        </div>
      </div>
    </section>

    <section class="impact-strip" aria-label="Impacto simbólico">
      <div class="shell impact-grid">
        <div class="impact-item reveal-item"><span aria-hidden="true">🌱</span><p><strong>1 boa ação</strong> pode inspirar centenas.</p></div>
        <div class="impact-divider" aria-hidden="true"></div>
        <div class="impact-item reveal-item"><span aria-hidden="true">🌍</span><p><strong>Imagine esse movimento</strong> acontecendo diariamente.</p></div>
      </div>
    </section>

    <section class="print-section section-space" aria-labelledby="card-heading">
      <div class="shell print-grid">
        <div class="reveal-item"><p class="hope-label">Leve a mensagem com você</p><h2 id="card-heading" class="hope-title light">Um lembrete para o futuro.</h2><p>Imprima, compartilhe ou deixe este cartão onde alguém possa encontrá-lo.</p><button id="print-card" type="button" class="hope-button">Imprimir cartão <span aria-hidden="true">⎙</span></button></div>
        <div class="a6-card reveal-item" id="printable-card">
          <div class="card-front">
            <span class="mini-earth" aria-hidden="true"></span>
            <small>Além do Rei do Pop apresenta</small>
            <h3>Heal the<br/>World Project</h3>
            <p id="card-front-copy">O futuro começa com uma escolha.</p>
            <div class="card-seal"><span>Mission Card</span><strong id="card-front-tag">Escolha do dia</strong></div>
          </div>
          <div class="card-back">
            <p id="card-back-label">Minha escolha para hoje:</p>
            <h4 id="card-back-title">Missão disponível</h4>
            <p id="card-back-question">Quem posso ajudar?</p>
            <div class="card-actions">
              <div><span>Faça agora</span><strong id="card-action">Clique para gerar uma missão</strong></div>
              <div><span>Motivo</span><strong id="card-reason">Transformar intenção em gesto concreto</strong></div>
            </div>
            <div class="qr-placeholder" aria-label="Espaço reservado para QR Code"><span>QR</span><small>aponte para o projeto</small></div>
          </div>
        </div>
      </div>
    </section>

    <section class="inspiration-section section-space">
      <div class="shell narrow reveal-item"><span class="quote-mark" aria-hidden="true">“</span><blockquote>Este projeto foi inspirado na mensagem de amor, esperança e responsabilidade coletiva presente na obra de Michael Jackson.</blockquote><p>Seu objetivo é transformar inspiração em ação.</p></div>
    </section>

    <section class="project-closing"><div class="shell"><p>O futuro não será construído apenas pela tecnologia.<br/><strong>Será construído pelas pessoas.</strong></p><span>Heal the World Project · {new Date().getFullYear()}</span></div></section>
  </div>
</BaseLayout>

<script>
  const missions = [
    { title: 'Unidade', text: 'Converse com alguém que pensa diferente de você e procure um ponto em comum antes de discordar.', action: 'Abrir espaço para ouvir antes de responder.', reason: 'Michael defendia união como linguagem pública e artística.', accent: '#62e6c5', accentSoft: '#133a42', surface: '#0d3447', tag: 'Convivência' },
    { title: 'Crianças', text: 'Apoie hoje uma ação concreta voltada para crianças, com tempo, recurso ou atenção.', action: 'Direcionar alguma ajuda para uma criança ou instituição confiável.', reason: 'A proteção da infância aparece em várias iniciativas do projeto Heal the World.', accent: '#f0d38f', accentSoft: '#3d2f18', surface: '#2b2130', tag: 'Infância' },
    { title: 'Empatia', text: 'Ouça alguém sem interromper e sem tentar resolver tudo na primeira resposta.', action: 'Dar atenção total por cinco minutos.', reason: 'Escuta ativa é o ponto de partida de qualquer gesto coletivo.', accent: '#86d8ff', accentSoft: '#1b3243', surface: '#0c2d46', tag: 'Escuta' },
    { title: 'Planeta', text: 'Reduza um desperdício visível hoje: água, energia, plástico ou comida.', action: 'Escolher uma prática que economize um recurso do dia.', reason: 'Cuidar da Terra é também cuidar das pessoas que vivem nela.', accent: '#8be7a5', accentSoft: '#16352a', surface: '#0e2a22', tag: 'Terra' },
    { title: 'Gratidão', text: 'Agradeça de forma direta a uma pessoa que melhorou o seu dia ou trabalho.', action: 'Mandar uma mensagem de gratidão agora.', reason: 'Reconhecer quem sustenta a rotina muda a atmosfera ao redor.', accent: '#d8b46a', accentSoft: '#3a2e1b', surface: '#2f2415', tag: 'Reconhecer' },
    { title: 'Paz', text: 'Evite alimentar uma briga, um boato ou uma reação impulsiva no dia de hoje.', action: 'Responder com calma, ou não responder.', reason: 'Paz não é passividade, é disciplina emocional aplicada ao mundo.', accent: '#6fd1c8', accentSoft: '#16353c', surface: '#0b2830', tag: 'Calma' },
    { title: 'Arte que une', text: 'Compartilhe uma música, dança ou obra que inspire cuidado em vez de cinismo.', action: 'Recomendar uma obra que motive alguém.', reason: 'A arte também é uma forma de educação afetiva.', accent: '#f3bf75', accentSoft: '#3b2914', surface: '#2b2010', tag: 'Arte' },
    { title: 'Justiça', text: 'Defenda alguém que esteja sendo tratado de forma injusta, mesmo que seja só com palavras.', action: 'Nomear o que é injusto, sem exagero nem omissão.', reason: 'Responsabilidade social exige posicionamento claro.', accent: '#9ad0ff', accentSoft: '#18314a', surface: '#12213d', tag: 'Direitos' },
    { title: 'Cuidado', text: 'Faça uma coisa útil para alguém que esteja cansado, sobrecarregado ou sozinho.', action: 'Oferecer ajuda prática antes de qualquer discurso.', reason: 'Cuidar é tornar a vida um pouco menos pesada para outra pessoa.', accent: '#7ce7b8', accentSoft: '#163324', surface: '#0f2b24', tag: 'Apoio' },
    { title: 'Legado', text: 'Transforme uma intenção boa em um hábito repetível para a próxima semana.', action: 'Escolher uma mudança pequena e mantê-la por sete dias.', reason: 'Legado sem prática vira frase. Com prática, vira cultura.', accent: '#f0d28c', accentSoft: '#392f18', surface: '#231d10', tag: 'Hábito' }
  ];

  const missionTitle = document.querySelector<HTMLElement>('#mission-title');
  const missionText = document.querySelector<HTMLElement>('#mission-text');
  const missionCount = document.querySelector<HTMLElement>('#mission-count');
  const missionButton = document.querySelector<HTMLButtonElement>('#generate-mission');
  const cardFrontCopy = document.querySelector<HTMLElement>('#card-front-copy');
  const cardBackLabel = document.querySelector<HTMLElement>('#card-back-label');
  const cardBackTitle = document.querySelector<HTMLElement>('#card-back-title');
  const cardBackQuestion = document.querySelector<HTMLElement>('#card-back-question');
  const cardAction = document.querySelector<HTMLElement>('#card-action');
  const cardReason = document.querySelector<HTMLElement>('#card-reason');
  const cardFrontTag = document.querySelector<HTMLElement>('#card-front-tag');
  const missionCard = document.querySelector<HTMLElement>('.mission-card');
  const printableCard = document.querySelector<HTMLElement>('#printable-card');
  let currentMission = -1;

  const applyMission = (index: number) => {
    const mission = missions[index];
    missionText?.classList.add('changing');
    missionCard?.style.setProperty('--mission-accent', mission.accent);
    missionCard?.style.setProperty('--mission-accent-soft', mission.accentSoft);
    printableCard?.style.setProperty('--print-front', `linear-gradient(145deg, #fff, ${mission.surface}14)`);
    printableCard?.style.setProperty('--print-back', `linear-gradient(145deg, ${mission.surface}, #082d42)`);
    printableCard?.style.setProperty('--print-accent', mission.accent);
    window.setTimeout(() => {
      if (missionTitle) missionTitle.textContent = mission.title;
      if (missionText) missionText.textContent = mission.text;
      if (missionCount) missionCount.textContent = `Missão ${String(index + 1).padStart(2, '0')} de ${missions.length}`;
      if (cardFrontCopy) cardFrontCopy.textContent = `${mission.title} · Heal the World`;
      if (cardFrontTag) cardFrontTag.textContent = mission.tag;
      if (cardBackLabel) cardBackLabel.textContent = `Minha escolha para hoje: ${mission.title}`;
      if (cardBackTitle) cardBackTitle.textContent = mission.title;
      if (cardBackQuestion) cardBackQuestion.textContent = mission.text;
      if (cardAction) cardAction.textContent = mission.action;
      if (cardReason) cardReason.textContent = mission.reason;
      missionText?.classList.remove('changing');
    }, 180);
  };

  missionButton?.addEventListener('click', () => {
    let nextMission: number;
    do nextMission = Math.floor(Math.random() * missions.length); while (nextMission === currentMission);
    currentMission = nextMission;
    applyMission(nextMission);
  });

  document.querySelector('#print-card')?.addEventListener('click', () => {
    if (currentMission < 0) {
      currentMission = Math.floor(Math.random() * missions.length);
      applyMission(currentMission);
    }
    window.setTimeout(() => window.print(), 240);
  });

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) { entry.target.classList.add('is-visible'); revealObserver.unobserve(entry.target); }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal-item').forEach((element) => revealObserver.observe(element));

  const earth = document.querySelector<HTMLElement>('.earth-wrap');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  window.addEventListener('scroll', () => {
    if (earth && !reduceMotion.matches && window.scrollY < window.innerHeight) earth.style.transform = `translate3d(0, ${window.scrollY * .08}px, 0)`;
  }, { passive: true });
</script>

<style>
  :global(body) { overflow-x: hidden; }
  .heal-page { --deep:#04172a; --ocean:#063659; --sky:#7fd9ff; --emerald:#34d5a6; --soft-gold:#d9c58b; --cloud:#f5f8f7; font-family: Inter, sans-serif; background:var(--deep); color:white; }
  .hero-hope { position:relative; min-height:calc(100svh - 4rem); overflow:hidden; background:radial-gradient(circle at 72% 48%, #0c4e70 0, #072a49 25%, #04172a 52%, #020b15 100%); }
  .stars { position:absolute; inset:-5%; opacity:.52; background-image:radial-gradient(circle, #fff 0 1px, transparent 1.5px),radial-gradient(circle, #7fd9ff 0 1px, transparent 1.5px); background-size:97px 97px,151px 151px; background-position:20px 30px,70px 80px; mask-image:linear-gradient(to right,transparent 0,#000 40%); animation:star-drift 24s ease-in-out infinite alternate; }
  .hero-glow { position:absolute; width:46rem; height:46rem; right:-9rem; top:50%; border-radius:50%; transform:translateY(-50%); background:#3ebea9; filter:blur(110px); opacity:.13; }
  .earth-wrap { position:absolute; width:min(55vw,760px); aspect-ratio:1; right:-7vw; top:50%; margin-top:min(-27vw,-380px); will-change:transform; }
  .earth { position:absolute; inset:8%; overflow:hidden; border-radius:50%; background:radial-gradient(circle at 30% 25%,#39a3d7 0,#087098 29%,#075376 53%,#03243f 78%); box-shadow:-35px 10px 80px #0009,inset -70px -25px 110px #00101acc,inset 20px 15px 50px #c9f7ff55,0 0 30px #91efff66,0 0 100px #24bfa255; animation:float 8s ease-in-out infinite; }
  .earth::after { content:''; position:absolute; inset:0; background:repeating-radial-gradient(ellipse at 30% 40%,#fff0 0 18px,#fff2 20px 22px,#fff0 24px 42px); opacity:.45; transform:rotate(-18deg); }
  .land { position:absolute; display:block; background:linear-gradient(135deg,#7bc971,#218e68 65%,#126749); filter:drop-shadow(0 0 8px #b5ffba55); opacity:.9; }
  .land-one { width:38%; height:27%; left:15%; top:19%; border-radius:62% 38% 53% 47% / 42% 31% 69% 58%; transform:rotate(-12deg); }
  .land-two { width:20%; height:38%; left:40%; top:45%; border-radius:62% 38% 80% 20% / 23% 57% 43% 77%; transform:rotate(16deg); }
  .land-three { width:29%; height:20%; right:-5%; top:30%; border-radius:70% 30% 54% 46%; }
  .orbit { position:absolute; inset:1%; border:1px solid #8de8ff26; border-radius:50%; transform:rotate(-24deg) scaleY(.4); box-shadow:0 0 15px #8de8ff22; }
  .hero-copy { text-shadow:0 2px 24px #000; }
  .hope-label { margin:0; color:var(--emerald); font-size:.7rem; font-weight:600; letter-spacing:.3em; text-transform:uppercase; }
  .hope-label.dark { color:#078467; }
  .hero-hope h1 { margin:1.4rem 0; max-width:800px; font-family:'Cormorant Garamond',serif; font-size:clamp(4.4rem,9vw,8.8rem); font-weight:500; letter-spacing:-.055em; line-height:.72; }
  .hero-hope h1 em { color:#a7f1e0; font-weight:500; }
  .hero-subtitle { max-width:590px; margin:2.4rem 0 2rem; color:#d8e7ed; font-size:clamp(1.1rem,2vw,1.4rem); line-height:1.7; }
  .hope-button { display:inline-flex; align-items:center; gap:.8rem; border:1px solid #9aeedc55; border-radius:999px; background:linear-gradient(135deg,#53deb7,#23b990); padding:.95rem 1.4rem; color:#031b18; font-size:.85rem; font-weight:700; box-shadow:0 12px 40px #1dd6a429; transition:transform .3s,box-shadow .3s,filter .3s; }
  .hope-button:hover { transform:translateY(-3px); box-shadow:0 18px 45px #1dd6a44d; filter:brightness(1.08); }
  .scroll-note { position:absolute; bottom:1.8rem; left:50%; z-index:2; margin:0; transform:translateX(-50%); color:#ffffff70; font-size:.65rem; letter-spacing:.22em; text-transform:uppercase; }
  .section-space { padding:clamp(6rem,11vw,10rem) 0; }
  .light-section { background:var(--cloud); color:#102d38; }
  .manifesto-grid { display:grid; gap:5rem; align-items:start; }
  .hope-title { margin:1rem 0 1.5rem; max-width:760px; font-family:'Cormorant Garamond',serif; font-size:clamp(3.3rem,6vw,6rem); font-weight:500; letter-spacing:-.04em; line-height:.92; }
  .hope-title.light { color:#fff; }
  .lead-copy,.section-heading>p:last-child { max-width:620px; color:#4f6870; font-size:1.1rem; line-height:1.85; }
  .principles { border-top:1px solid #123b4926; }
  .principle { display:grid; grid-template-columns:3rem 1fr; gap:1rem; padding:2rem 0; border-bottom:1px solid #123b4926; }
  .principle>span { color:#16866d; font-size:.7rem; letter-spacing:.15em; }
  .principle h3 { margin:0 0 .5rem; font-family:'Cormorant Garamond',serif; font-size:1.85rem; }
  .principle p { margin:0; color:#5c7178; line-height:1.7; }
  .mission-section { position:relative; overflow:hidden; background:radial-gradient(circle at 50% 55%,#0b5470,#04233d 45%,#031526 78%); }
  .mission-section::before { content:''; position:absolute; inset:0; opacity:.15; background-image:linear-gradient(#74e6d51a 1px,transparent 1px),linear-gradient(90deg,#74e6d51a 1px,transparent 1px); background-size:55px 55px; mask-image:radial-gradient(circle,#000,transparent 68%); }
  .mission-card { position:relative; width:min(100%,760px); min-height:300px; margin:3rem auto 2rem; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3rem; border:1px solid #90f5dc35; border-radius:2rem; background:#ffffff0b; box-shadow:inset 0 1px #ffffff19,0 30px 100px #0005; backdrop-filter:blur(14px); }
  .mission-card { --mission-accent:#62e6c5; --mission-accent-soft:#133a42; background:radial-gradient(circle at top, color-mix(in srgb, var(--mission-accent) 16%, transparent), transparent 52%), linear-gradient(180deg, color-mix(in srgb, var(--mission-accent-soft) 58%, #082d42 42%), #082d42); border-color: color-mix(in srgb, var(--mission-accent) 40%, transparent); }
  .mission-card::before { content:''; position:absolute; inset:-1px; border-radius:inherit; background:linear-gradient(135deg, color-mix(in srgb, var(--mission-accent) 24%, #fff), transparent 35%, color-mix(in srgb, var(--mission-accent) 28%, transparent)); pointer-events:none; mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0); mask-composite:exclude; padding:1px; }
  .mission-icon { color:var(--mission-accent); font-size:2.2rem; text-shadow:0 0 25px color-mix(in srgb, var(--mission-accent) 60%, transparent); }
  #mission-title { margin:1.2rem 0 .75rem; color:#9af3df; font-size:.76rem; font-weight:700; letter-spacing:.32em; text-transform:uppercase; }
  #mission-text { margin:0 0 1.25rem; max-width:44rem; color:#eefcf9; font-family:'Cormorant Garamond',serif; font-size:clamp(2rem,4vw,3.2rem); line-height:1.05; transition:opacity .18s,transform .18s; }
  #mission-text.changing { opacity:0; transform:translateY(8px); }
  #mission-count { color:#ffffff70; font-size:.65rem; letter-spacing:.2em; text-transform:uppercase; }
  .section-heading { margin-bottom:3.5rem; }
  .section-heading.center { display:flex; flex-direction:column; align-items:center; text-align:center; }
  .reflection-grid { display:grid; gap:1rem; }
