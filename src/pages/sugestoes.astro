---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';

const categories = [
  'Conteúdo novo',
  'Página nova',
  'Correção',
  'Fonte ou referência',
  'Ideia visual',
  'Melhoria técnica'
];
---

<BaseLayout
  theme="light"
  title="Sugestões para o site | Além do Rei do Pop"
  description="Envie ideias de conteúdos, páginas novas, correções e melhorias para o projeto independente Além do Rei do Pop."
>
  <section class="py-24">
    <div class="shell grid gap-14 lg:grid-cols-[.72fr_1fr]">
      <div>
        <SectionTitle
          eyebrow="Sugestões"
          title="Ajude a imaginar os próximos passos do site."
          text="Este espaço foi criado para organizar ideias de fãs sobre conteúdos, páginas novas, correções, referências e melhorias que podem deixar o projeto mais completo."
        />
        <div class="mt-8 rounded-2xl border border-black/10 bg-white p-6 shadow-sm">
          <h2 class="font-display text-3xl">O que sugerir?</h2>
          <ul class="mt-5 space-y-3 text-sm leading-6 text-black/62">
            <li>Novas páginas sobre fases, turnês, álbuns, videoclipes ou performances.</li>
            <li>Correções de datas, nomes, links, fontes ou informações históricas.</li>
            <li>Ideias de seções para fãs, galeria, linha do tempo e discografia.</li>
            <li>Referências confiáveis que ajudem a melhorar textos já publicados.</li>
          </ul>
        </div>
      </div>

      <form class="rounded-3xl bg-white p-7 shadow-xl sm:p-10" aria-describedby="suggestion-status" data-suggestion-form>
        <div class="grid gap-6 sm:grid-cols-2">
          <label class="text-sm font-medium">
            Seu nome
            <input required name="name" autocomplete="name" class="mt-2 w-full rounded-xl border border-black/15 bg-paper px-4 py-3" />
          </label>
          <label class="text-sm font-medium">
            Tipo de sugestão
            <select required name="category" class="mt-2 w-full rounded-xl border border-black/15 bg-paper px-4 py-3">
              <option value="">Selecione</option>
              {categories.map((category) => <option value={category}>{category}</option>)}
            </select>
          </label>
          <label class="text-sm font-medium sm:col-span-2">
            Título da ideia
            <input required name="title" maxlength="120" placeholder="Ex: página sobre a Dangerous World Tour" class="mt-2 w-full rounded-xl border border-black/15 bg-paper px-4 py-3" />
          </label>
          <label class="text-sm font-medium sm:col-span-2">
            Descreva sua sugestão
            <textarea required name="suggestion" maxlength="1200" rows="7" class="mt-2 w-full resize-y rounded-xl border border-black/15 bg-paper px-4 py-3"></textarea>
          </label>
          <label class="text-sm font-medium sm:col-span-2">
            Fonte ou link de referência, se tiver
            <input name="source" maxlength="240" placeholder="Opcional" class="mt-2 w-full rounded-xl border border-black/15 bg-paper px-4 py-3" />
          </label>
        </div>
        <button class="btn-primary mt-7" type="submit">Enviar sugestão</button>
        <p id="suggestion-status" class="mt-4 min-h-6 text-sm text-[#71551e]" aria-live="polite">Demonstração: nenhum dado será enviado nesta versão.</p>
        <!-- Integração futura: função Netlify própria para sugestões, painel de moderação e armazenamento separado. -->
      </form>
    </div>
  </section>

  <section class="bg-navy py-20 text-white">
    <div class="shell grid gap-6 md:grid-cols-3">
      <article class="card-dark">
        <p class="eyebrow">Conteúdo</p>
        <h2 class="mt-4 font-display text-3xl text-champagne">Novas pesquisas</h2>
        <p class="mt-3 leading-7 text-white/58">Ideias para textos, biografias, análises e conteúdos especiais.</p>
      </article>
      <article class="card-dark">
        <p class="eyebrow">Páginas</p>
        <h2 class="mt-4 font-display text-3xl text-champagne">Novas seções</h2>
        <p class="mt-3 leading-7 text-white/58">Sugestões de áreas que poderiam tornar a navegação mais completa.</p>
      </article>
      <article class="card-dark">
        <p class="eyebrow">Qualidade</p>
        <h2 class="mt-4 font-display text-3xl text-champagne">Correções</h2>
        <p class="mt-3 leading-7 text-white/58">Ajustes de informação, acessibilidade, visual ou funcionamento.</p>
      </article>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelector<HTMLFormElement>('[data-suggestion-form]')?.addEventListener('submit', (event) => {
    event.preventDefault();
    const status = document.querySelector('#suggestion-status');
    if (status) status.textContent = 'Obrigado. O envio de sugestões será conectado em uma versão futura.';
  });
</script>
