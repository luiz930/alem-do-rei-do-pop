---
import BaseLayout from '../layouts/BaseLayout.astro'; import SectionTitle from '../components/SectionTitle.astro'; import TypographicArt from '../components/TypographicArt.astro';
const works: Array<{ title: string; variant: 'portrait' | 'album' | 'dance' | 'stage' | 'heart' | 'archive' | 'moonwalk'; description: string; }> = [{title:'Rosto em memória',variant:'portrait',description:'As letras M e J constroem uma presença sem utilizar fotografia.'},{title:'Órbita sonora',variant:'album',description:'Anos e algarismos imaginam a música como movimento contínuo.'},{title:'Corpo em ritmo',variant:'dance',description:'Caracteres em sequência transformam gesto e pausa em silhueta.'},{title:'Palco de letras',variant:'stage',description:'A presença é sugerida por palavras, datas e expectativa.'},{title:'Arquivo pop',variant:'archive',description:'Linhas de números organizam a memória como um acervo visual.'},{title:'Coração de fãs',variant:'heart',description:'Letras, datas e palavras afetivas formam um gesto de homenagem.'},{title:'Disco numérico',variant:'album',description:'Camadas de números registram o pulso de uma obra musical.'},{title:'Moonwalk em texto',variant:'moonwalk',description:'Movimento, pausa e trajetória aparecem como desenho tipográfico.'},{title:'Constelação pop',variant:'stage',description:'Iniciais e datas formam um arquivo afetivo sempre incompleto.'}];
---
<BaseLayout title="Galeria autoral | Além do Rei do Pop" description="Galeria de composições abstratas e autorais inspiradas em palco, luz e música."><section class="py-24"><div class="shell"><SectionTitle eyebrow="Galeria autoral" title="Presença em letras e números" text="Nenhuma fotografia ou arte oficial é usada. As composições são construídas somente com tipografia, datas e símbolos do próprio site." /><div class="mt-16 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">{works.map((work,i)=><article class="group overflow-hidden rounded-2xl border border-white/10 bg-white/[.03]"><TypographicArt variant={work.variant} ratio="wide" label={`Arte tipográfica original: ${work.title}`} title={work.title} index={i} /><div class="p-6"><h2 class="font-display text-3xl">{work.title}</h2><p class="mt-1 text-xs uppercase tracking-[.18em] text-gold">Estúdio Além</p><p class="mt-4 leading-7 text-white/55">{work.description}</p></div></article>)}</div></div></section></BaseLayout>
