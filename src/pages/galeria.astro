---
import BaseLayout from '../layouts/BaseLayout.astro'; import SectionTitle from '../components/SectionTitle.astro';
const works=[['Luz que permanece','Estúdio Além','Feixes dourados atravessam o silêncio antes do espetáculo.'],['Órbita sonora','Estúdio Além','Círculos concêntricos imaginam a música como movimento contínuo.'],['Noite elétrica','Estúdio Além','Geometria azul e dourada evoca ritmo sem representar uma pessoa.'],['Palco vazio','Estúdio Além','A presença é sugerida pelo espaço, pela luz e pela expectativa.'],['Pulso','Estúdio Além','Linhas mínimas registram a tensão entre pausa e explosão.'],['Constelação pop','Estúdio Além','Pontos de luz formam um arquivo afetivo sempre incompleto.']];
---
<BaseLayout title="Galeria autoral | Além do Rei do Pop" description="Galeria de composições abstratas e autorais inspiradas em palco, luz e música."><section class="py-24"><div class="shell"><SectionTitle eyebrow="Galeria autoral" title="Presença sem retrato" text="Nenhuma imagem real ou oficial é usada. Estes placeholders abstratos foram criados com formas e gradientes do próprio site." /><div class="mt-16 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">{works.map(([title,author,description],i)=><article class="group overflow-hidden rounded-2xl border border-white/10 bg-white/[.03]"><div class:list={['relative aspect-[4/3] overflow-hidden', i%3===0?'bg-[radial-gradient(circle_at_50%_80%,#c7a65b55,transparent_40%),linear-gradient(135deg,#0c1728,#08090c)]':i%3===1?'bg-[repeating-radial-gradient(circle_at_50%_50%,#c7a65b33_0_1px,transparent_2px_35px),#08090c]':'bg-[linear-gradient(115deg,transparent_30%,#c7a65b33_31%,transparent_33%),linear-gradient(35deg,#0c1728,#08090c)]']} role="img" aria-label={`Arte abstrata original: ${title}`}><span class="absolute inset-8 border border-gold/20 transition duration-700 group-hover:scale-105 group-hover:rotate-3"></span></div><div class="p-6"><h2 class="font-display text-3xl">{title}</h2><p class="mt-1 text-xs uppercase tracking-[.18em] text-gold">{author}</p><p class="mt-4 leading-7 text-white/55">{description}</p></div></article>)}</div></div></section></BaseLayout>
