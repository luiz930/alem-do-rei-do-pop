---
import BaseLayout from '../layouts/BaseLayout.astro'; import SectionTitle from '../components/SectionTitle.astro';
const works=[{title:'1977',image:'/assets/licensed/michael-jackson-1977.jpg',source:'https://commons.wikimedia.org/wiki/File:Michael_Jackson_1977.JPG',description:'Imagem licenciada de fase inicial, usada como registro visual histórico.'},{title:'1984',image:'/assets/licensed/michael-jackson-1984.jpg',source:'https://commons.wikimedia.org/wiki/File:Michael_Jackson_1984.jpg',description:'Retrato licenciado associado ao período de consolidação global.'},{title:'1988',image:'/assets/licensed/michael-jackson-in-1988.jpg',source:'https://commons.wikimedia.org/wiki/File:Michael_Jackson_in_1988.jpg',description:'Foto licenciada de um momento maduro da carreira.'},{title:'Thriller 25',image:'/assets/licensed/thriller-25.jpg',source:'https://commons.wikimedia.org/wiki/File:Thriller_25.jpg',description:'Arte licenciada relacionada à obra mais conhecida do catálogo.'},{title:'Dangerous',image:'/assets/licensed/dangerous-logo.svg',source:'https://commons.wikimedia.org/wiki/File:Michael_Jackson_-_Dangerous_(logo).svg',description:'Marca gráfica licenciada usada como referência visual.'},{title:'Invincible',image:'/assets/licensed/invincible.jpg',source:'https://commons.wikimedia.org/wiki/File:Michael_Jackson_INVINCIBLE.jpg',description:'Imagem licenciada para fechar a galeria com uma fase final de estúdio.'}];
---
<BaseLayout title="Galeria autoral | Além do Rei do Pop" description="Galeria de imagens licenciadas e referências visuais da trajetória de Michael Jackson."><section class="py-24"><div class="shell"><SectionTitle eyebrow="Galeria autoral" title="Imagens licenciadas" text="Esta galeria reúne fotos e marcas gráficas com licença verificada. Cada item aponta para a respectiva fonte original." /><div class="mt-16 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">{works.map((work)=><article class="group overflow-hidden rounded-2xl border border-white/10 bg-white/[.03]"><figure class="overflow-hidden rounded-2xl bg-black/25"><img src={work.image} alt={work.title} class="aspect-[4/3] w-full object-cover object-top transition duration-700 group-hover:scale-[1.02]" loading="lazy" decoding="async" /><figcaption class="border-t border-white/10 px-4 py-3 text-[.62rem] uppercase tracking-[.24em] text-white/35"><a href={work.source} target="_blank" rel="noopener noreferrer" class="text-champagne underline decoration-gold/40 underline-offset-4">Fonte licenciada</a></figcaption></figure><div class="p-6"><h2 class="font-display text-3xl">{work.title}</h2><p class="mt-4 leading-7 text-white/55">{work.description}</p></div></article>)}</div></div></section></BaseLayout>
