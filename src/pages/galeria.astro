---
import BaseLayout from '../layouts/BaseLayout.astro'; import SectionTitle from '../components/SectionTitle.astro'; import TypographicArt from '../components/TypographicArt.astro';
const works=[['Rosto em memória','Estúdio Além','As letras M e J constroem uma presença sem utilizar fotografia.'],['Órbita sonora','Estúdio Além','Anos e algarismos imaginam a música como movimento contínuo.'],['Corpo em ritmo','Estúdio Além','Caracteres em sequência transformam gesto e pausa em silhueta.'],['Palco de letras','Estúdio Além','A presença é sugerida por palavras, datas e expectativa.'],['Disco numérico','Estúdio Além','Camadas de números registram o pulso de uma obra musical.'],['Constelação pop','Estúdio Além','Iniciais e datas formam um arquivo afetivo sempre incompleto.']];
---
<BaseLayout title="Galeria autoral | Além do Rei do Pop" description="Galeria de composições abstratas e autorais inspiradas em palco, luz e música."><section class="py-24"><div class="shell"><SectionTitle eyebrow="Galeria autoral" title="Presença em letras e números" text="Nenhuma fotografia ou arte oficial é usada. As composições são construídas somente com tipografia, datas e símbolos do próprio site." /><div class="mt-16 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">{works.map(([title,author,description],i)=><article class="group overflow-hidden rounded-2xl border border-white/10 bg-white/[.03]"><TypographicArt variant={i % 3 === 0 ? 'portrait' : i % 3 === 1 ? 'album' : 'dance'} ratio="wide" label={`Arte tipográfica original: ${title}`} title={title} index={i} /><div class="p-6"><h2 class="font-display text-3xl">{title}</h2><p class="mt-1 text-xs uppercase tracking-[.18em] text-gold">{author}</p><p class="mt-4 leading-7 text-white/55">{description}</p></div></article>)}</div></div></section></BaseLayout>
