---
import BaseLayout from '../layouts/BaseLayout.astro';

const pixKey = 'Chave Pix = CPF 40957591861';
const pixHolder = 'Luiz Henrique Garcia - Para o site do rei do pop';
---

<BaseLayout
  title="Apoie o projeto | Além do Rei do Pop"
  description="Contribua via Pix para apoiar o desenvolvimento do site independente Além do Rei do Pop."
>
  <section class="relative overflow-hidden bg-ink py-24 text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_25%_20%,rgba(199,166,91,.2),transparent_34%),linear-gradient(135deg,rgba(12,23,40,.92),rgba(8,9,12,1))]" aria-hidden="true"></div>
    <div class="shell relative grid items-center gap-12 lg:grid-cols-[1fr_.72fr]">
      <div>
        <p class="eyebrow">Apoie</p>
        <h1 class="display mt-5 max-w-4xl text-5xl sm:text-6xl lg:text-7xl">Ajude este tributo independente a continuar crescendo.</h1>
        <p class="mt-7 max-w-2xl text-lg leading-8 text-white/68">
          Este site nasceu da admiração pela obra, pela história e pelo impacto cultural de Michael Jackson. Toda contribuição ajuda a manter o desenvolvimento, melhorar páginas, organizar conteúdos e preservar este espaço feito por fãs.
        </p>
      </div>

      <aside class="rounded-2xl border border-gold/25 bg-white/[.055] p-6 shadow-gold backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-[.28em] text-gold">Contribuição via Pix</p>
        <h2 class="mt-4 font-display text-3xl text-champagne">Chave Pix</h2>
        <div class="mt-5 rounded-xl border border-white/10 bg-black/25 p-4">
          <p class="text-xs uppercase tracking-[.2em] text-white/42">Titular</p>
          <p class="mt-2 text-sm font-semibold text-white">{pixHolder}</p>
          <p class="mt-5 text-xs uppercase tracking-[.2em] text-white/42">Chave</p>
          <p id="pix-key" class="mt-2 break-all rounded-lg bg-white/[.06] px-3 py-3 font-mono text-sm text-champagne">{pixKey}</p>
        </div>
        <button
          id="copy-pix"
          type="button"
          class="mt-5 inline-flex w-full items-center justify-center rounded-full bg-gold px-5 py-3 text-sm font-semibold text-ink transition hover:-translate-y-0.5 hover:bg-champagne"
          data-pix={pixKey}
        >
          Copiar chave Pix
        </button>
        <p id="copy-status" class="mt-3 min-h-5 text-center text-sm text-white/55" aria-live="polite"></p>
      </aside>
    </div>
  </section>

  <section class="bg-paper py-20 text-[#202126]">
    <div class="shell grid gap-8 lg:grid-cols-3">
      <article class="rounded-2xl bg-white p-7 shadow-sm">
        <p class="eyebrow">01</p>
        <h2 class="mt-4 font-display text-3xl">Desenvolvimento</h2>
        <p class="mt-3 leading-7 text-black/58">Ajuda a manter melhorias técnicas, correções e novas páginas para o site.</p>
      </article>
      <article class="rounded-2xl bg-white p-7 shadow-sm">
        <p class="eyebrow">02</p>
        <h2 class="mt-4 font-display text-3xl">Pesquisa</h2>
        <p class="mt-3 leading-7 text-black/58">Apoia a organização de fontes, textos autorais e conteúdos com contexto histórico.</p>
      </article>
      <article class="rounded-2xl bg-[#132139] p-7 text-white shadow-sm">
        <p class="eyebrow">03</p>
        <h2 class="mt-4 font-display text-3xl">Memória</h2>
        <p class="mt-3 leading-7 text-white/62">Fortalece um espaço independente, respeitoso e feito para fãs.</p>
      </article>
    </div>
  </section>
</BaseLayout>

<script>
  const button = document.querySelector<HTMLButtonElement>('#copy-pix');
  const status = document.querySelector<HTMLElement>('#copy-status');

  button?.addEventListener('click', async () => {
    const pix = button.dataset.pix ?? '';
    try {
      await navigator.clipboard.writeText(pix);
      if (status) status.textContent = 'Chave Pix copiada.';
    } catch {
      if (status) status.textContent = 'Nao foi possivel copiar automaticamente.';
    }
  });
</script>
