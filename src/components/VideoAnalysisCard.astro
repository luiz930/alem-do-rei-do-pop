---
const { video } = Astro.props;
---
<article class="card-dark"><div class="flex flex-wrap items-start justify-between gap-3"><h2 class="font-display text-3xl">{video.title}</h2><span class="rounded-full border border-gold/30 px-3 py-1 text-xs text-gold">{video.year}</span></div><p class="mt-5 leading-7 text-white/60">{video.analysis}</p><div class="mt-5 grid gap-4 border-t border-white/10 pt-5 sm:grid-cols-2"><div><h3 class="text-sm text-gold">Impacto visual</h3><p class="mt-2 text-sm leading-6 text-white/50">{video.impact}</p></div><div><h3 class="text-sm text-gold">Curiosidade</h3><p class="mt-2 text-sm leading-6 text-white/50">{video.fact}</p></div></div></article>
