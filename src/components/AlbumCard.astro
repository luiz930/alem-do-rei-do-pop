---
const { album, index } = Astro.props;
---
<article class="card-dark group flex h-full flex-col"><div class="relative mb-6 aspect-square overflow-hidden rounded-xl bg-gradient-to-br from-navy via-ink to-[#3d3017]" role="img" aria-label={`Arte abstrata original para representar ${album.name}`}><span class="absolute inset-[15%] rounded-full border border-gold/35 transition duration-700 group-hover:rotate-12"></span><span class="absolute inset-[28%] rounded-full border border-white/10"></span><span class="absolute inset-[43%] rounded-full bg-gold/70"></span><span class="absolute bottom-4 left-4 text-5xl font-display text-white/10">0{index + 1}</span></div><div class="flex items-baseline justify-between gap-3"><h2 class="font-display text-3xl">{album.name}</h2><span class="text-sm text-gold">{album.year}</span></div><p class="mt-4 leading-7 text-white/60">{album.description}</p><dl class="mt-5 space-y-4 border-t border-white/10 pt-5 text-sm"><div><dt class="text-gold">Impacto cultural</dt><dd class="mt-1 leading-6 text-white/55">{album.impact}</dd></div><div><dt class="text-gold">Curiosidade</dt><dd class="mt-1 leading-6 text-white/55">{album.fact}</dd></div></dl>{album.link && <a class="mt-auto pt-6 text-sm text-champagne underline decoration-gold/50 underline-offset-4" href={album.link} target="_blank" rel="noopener noreferrer">Consultar fonte oficial <span class="sr-only">(abre em nova aba)</span></a>}</article>
