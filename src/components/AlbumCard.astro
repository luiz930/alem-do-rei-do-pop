---
import TypographicArt from './TypographicArt.astro';
const { album, index } = Astro.props;
---
<article class="card-dark group flex h-full flex-col"><div class="mb-6"><TypographicArt variant="album" label={`Capa tipográfica autoral para representar o álbum ${album.name}`} title={`${album.name} • ${album.year}`} index={index} /></div><div class="flex items-baseline justify-between gap-3"><h2 class="font-display text-3xl">{album.name}</h2><span class="text-sm text-gold">{album.year}</span></div><p class="mt-4 leading-7 text-white/60">{album.description}</p><dl class="mt-5 space-y-4 border-t border-white/10 pt-5 text-sm"><div><dt class="text-gold">Impacto cultural</dt><dd class="mt-1 leading-6 text-white/55">{album.impact}</dd></div><div><dt class="text-gold">Curiosidade</dt><dd class="mt-1 leading-6 text-white/55">{album.fact}</dd></div></dl>{album.link && <a class="mt-auto pt-6 text-sm text-champagne underline decoration-gold/50 underline-offset-4" href={album.link} target="_blank" rel="noopener noreferrer">Consultar fonte oficial <span class="sr-only">(abre em nova aba)</span></a>}</article>
