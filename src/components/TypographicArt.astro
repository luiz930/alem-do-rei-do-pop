---
interface Props {
  variant?: 'portrait' | 'album' | 'dance' | 'stage' | 'heart' | 'archive' | 'moonwalk';
  label: string;
  title?: string;
  index?: number;
  ratio?: 'square' | 'wide';
}

const {
  variant = 'portrait',
  label,
  title = 'MICHAEL JACKSON',
  index = 0,
  ratio = 'square'
