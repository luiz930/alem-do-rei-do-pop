const number = String(index + 1).padStart(2, '0');
---

<div class:list={['type-art', `type-art--${variant}`, ratio === 'wide' && 'type-art--wide']} role="img" aria-label={label}>
  <div class="type-art__stream" aria-hidden="true">MICHAEL • JACKSON • 1958 • 2009 • KING • POP • RHYTHM • DANCE • MUSIC •</div>
  <pre class="type-art__drawing" aria-hidden="true">{art}</pre>
  <div class="type-art__meta" aria-hidden="true">
    <span>{number}</span>
    <strong>{title}</strong>
  </div>
</div>

<style>
  .type-art {
    --art-accent: #c7a65b;
    position: relative;
    isolation: isolate;
    display: grid;
    aspect-ratio: 1;
    place-items: center;
    overflow: hidden;
    border: 1px solid rgb(199 166 91 / .2);
    border-radius: .9rem;
    background:
      radial-gradient(circle at 50% 43%, rgb(199 166 91 / .15), transparent 34%),
      linear-gradient(145deg, #111e32, #08090c 68%);
    box-shadow: inset 0 0 70px rgb(0 0 0 / .36);
  }
  .type-art--wide { aspect-ratio: 4 / 3; border-radius: 1.5rem; }
  .type-art--album { --art-accent: #f2dfae; }
  .type-art--dance { --art-accent: #d1b469; background: radial-gradient(circle at 70% 35%, rgb(199 166 91 / .2), transparent 32%), #08090c; }
  .type-art--stage { background: linear-gradient(160deg, #132139, #08090c 70%); }
  .type-art::before {
    content: '';
    position: absolute;
    inset: 7%;
    z-index: -1;
    border: 1px solid rgb(199 166 91 / .14);
    transition: transform .7s ease, border-color .7s ease;
  }
  .type-art:hover::before { transform: scale(.97); border-color: rgb(199 166 91 / .42); }
  .type-art__stream {
    position: absolute;
    inset: 0;
    overflow: hidden;
    color: rgb(242 223 174 / .055);
    font: 700 clamp(.65rem, 1.2vw, 1rem)/1.9 ui-monospace, SFMono-Regular, Consolas, monospace;
    letter-spacing: .22em;
    overflow-wrap: anywhere;
    transform: rotate(-8deg) scale(1.15);
  }
  .type-art__drawing {
    z-index: 1;
    margin: 0;
    color: var(--art-accent);
    font: 700 clamp(.42rem, 1.05vw, .82rem)/1.02 ui-monospace, SFMono-Regular, Consolas, monospace;
    letter-spacing: -.055em;
    text-align: center;
    text-shadow: 0 0 20px rgb(199 166 91 / .3);
    white-space: pre;
    transition: transform .7s ease, color .7s ease;
  }
  .type-art:hover .type-art__drawing { transform: scale(1.025); color: #f2dfae; }
  .type-art__meta {
    position: absolute;
    right: 1rem;
    bottom: .85rem;
    left: 1rem;
    z-index: 2;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    color: rgb(255 255 255 / .34);
    font: 600 .56rem/1.2 Inter, sans-serif;
    letter-spacing: .22em;
  }
  .type-art__meta span { color: rgb(199 166 91 / .6); font-family: Georgia, serif; font-size: 1.5rem; letter-spacing: 0; }
  .type-art__meta strong { max-width: 70%; text-align: right; }
  @media (max-width: 420px) {
    .type-art__drawing { font-size: 1.8vw; }
  }
  @media (prefers-reduced-motion: reduce) {
    .type-art::before, .type-art__drawing { transition: none; }
  }
</style>
