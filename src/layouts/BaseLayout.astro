---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
interface Props { title: string; description: string; theme?: 'dark' | 'light'; }
const { title, description, theme = 'dark' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08090c" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(`${base}og-abstract.svg`, Astro.site)} />
    <title>{title}</title>
  </head>
<body class:list={[theme === 'light' && 'reading']}>
    <a href="#conteudo" class="sr-only z-[100] bg-gold p-3 text-ink focus:not-sr-only focus:fixed focus:left-3 focus:top-3">Pular para o conteúdo</a>
    <Header />
    <div id="site-notice" class="site-notice" role="dialog" aria-modal="true" aria-labelledby="site-notice-title" aria-describedby="site-notice-description" hidden>
      <div class="site-notice__panel">
        <p class="site-notice__eyebrow">Aviso do projeto</p>
        <h2 id="site-notice-title" class="site-notice__title">Site em construção</h2>
        <p id="site-notice-description" class="site-notice__text">Este projeto ainda está recebendo ajustes. Algumas áreas podem ter bugs, partes incompletas ou interações que ainda não foram finalizadas.</p>
        <div class="site-notice__actions">
          <button id="site-notice-close" class="site-notice__button" type="button">Entendi</button>
        </div>
      </div>
    </div>
    <main id="conteudo"><slot /></main>
    <Footer />
    <script>
      const noticeKey = 'site-notice-dismissed-v1';
      const notice = document.querySelector<HTMLElement>('#site-notice');
      const closeButton = document.querySelector<HTMLButtonElement>('#site-notice-close');

      if (notice && !localStorage.getItem(noticeKey)) {
        notice.hidden = false;
        document.body.style.overflow = 'hidden';
      }

      const dismissNotice = () => {
        localStorage.setItem(noticeKey, '1');
        if (notice) notice.hidden = true;
        document.body.style.overflow = '';
      };

      closeButton?.addEventListener('click', dismissNotice);
      notice?.addEventListener('click', (event) => {
        if (event.target === notice) dismissNotice();
      });
      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !notice?.hidden) dismissNotice();
      });
    </script>
  </body>
</html>
